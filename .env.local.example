# Copy this file to .env.local and fill in values from your Supabase project.
# Supabase dashboard -> Project Settings -> API
# Note: .env.local is gitignored (matched by *.local) so your keys stay out of git.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Web Push: the VAPID PUBLIC key (safe to expose; the private key lives only in
# Supabase function secrets, never here). Generate with:
#   npx web-push generate-vapid-keys
# Must ALSO be set in the Vercel project env (Production + Preview) for push to
# work on the live site.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
